ANTHROPIC_API_KEY=sk-ant-your-key-here

# Only needed if publishing this to the public internet (not for LAN-only use).
# Set a password here to require sign-in before anyone can use the app — this
# app handles confidential legal documents, so set this before sharing a link.
APP_PASSWORD=

# Optional: keeps everyone logged in across server restarts. If unset, a
# random key is generated at startup and everyone is logged out on restart.
FLASK_SECRET_KEY=
